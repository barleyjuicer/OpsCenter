# Private local data. Keep placeholders and README files only.
data/*
!data/.gitkeep
!data/README.md
exports/*
!exports/.gitkeep
!exports/README.md
reports/*
!reports/.gitkeep
!reports/README.md

# Local workspace and packaged release outputs
outputs/
work/

# Databases and local state
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm

# Logs, screenshots, and generated media
logs/
*.log
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.bmp
*.tiff

# Python environments and caches
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Build and packaging artifacts
build/
dist/
*.egg-info/
*.whl
*.tar.gz
*.zip
*.exe
*.msi
*.app
*.dmg

# Streamlit and editor state
.streamlit/
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
